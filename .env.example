# ============================================================
# iMinds Tutorials — Root Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/iminds_tutorials

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Supabase (for Storage) ─────────────────────────────────
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Storage Provider ───────────────────────────────────────
# 'supabase' (default) | 'r2' (Cloudflare R2) | 's3'
STORAGE_PROVIDER=supabase

# ── Cloudflare R2 (optional — for future migration) ────────
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-key-id
# R2_SECRET_ACCESS_KEY=your-secret
# R2_BUCKET_NAME=iminds-files
# R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── Payment Gateway ────────────────────────────────────────
# 'mock' | 'stripe' | 'telr'
PAYMENT_GATEWAY=mock

# Stripe UAE (when ready)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Telr (when ready)
# TELR_STORE_ID=12345
# TELR_AUTH_KEY=your-auth-key
# TELR_CURRENCY=AED
# TELR_TEST_MODE=true

# ── Backend ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# ── Web App ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
